{
  "name": "apolaki-tests",
  "version": "1.0.0",
  "description": "End-to-end, integration, and regression test suite for the Apolaki Solar Platform",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "mocha --timeout 30000 --recursive 'api/**/*.test.js'",
    "test:e2e": "mocha --timeout 120000 --recursive 'e2e/**/*.test.js'",
    "test:cucumber": "cucumber-js --require cucumber/steps/**/*.js cucumber/features/**/*.feature",
    "test:regression": "mocha --timeout 120000 --recursive 'regression/**/*.test.js'",
    "test:regression:api": "mocha --timeout 120000 'regression/fullPlatform.test.js'",
    "test:regression:ui": "mocha --timeout 120000 'regression/uiRegression.test.js'",
    "test:smoke": "mocha --timeout 60000 --grep '@smoke' --recursive '{api,e2e}/**/*.test.js'",
    "test:report": "mocha --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=regression-report --recursive '{api,e2e,regression}/**/*.test.js'",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chai": "^5.1.0",
    "dotenv": "^17.3.1",
    "selenium-webdriver": "^4.27.0",
    "chromedriver": "^132.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "mocha": "^11.0.0",
    "mochawesome": "^7.1.3",
    "supertest": "^7.0.0"
  }
}
