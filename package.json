{
  "name": "apolaki-solar-platform",
  "version": "2.0.0",
  "description": "Apolaki Solar Platform - Comprehensive solar energy management system",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node middleware/netlify-db-service/src/server.js",
    "dev": "npm run dev:all",
    "dev:all": "npm-run-all -p dev:frontend dev:backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix middleware/netlify-db-service",
    "dev:db": "docker-compose -f config/docker-compose.yml up postgres redis",
    "dev:full": "npm-run-all -p dev:db dev:all",
    "build": "npm run build:all",
    "build:all": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm ci --prefix middleware/netlify-db-service",
    "build:netlify": "npm run build:all",
    "test": "npm run test:all",
    "test:all": "npm-run-all test:frontend test:backend",
    "test:frontend": "npm run test --prefix frontend 2>/dev/null || true",
    "test:backend": "npm run test --prefix middleware/netlify-db-service 2>/dev/null || true",
    "lint": "npm run lint:all",
    "lint:all": "npm-run-all lint:frontend lint:backend",
    "lint:frontend": "npm run lint --prefix frontend 2>/dev/null || true",
    "lint:backend": "echo 'No linter configured for backend'",
    "preview": "npm run preview --prefix frontend",
    "setup": "npm ci && npm ci --prefix frontend && npm ci --prefix middleware/netlify-db-service && npm run db:init",
    "db:init": "docker-compose -f config/docker-compose.yml up -d postgres && sleep 5 && docker-compose -f config/docker-compose.yml exec -T postgres psql -U apolaki_user -d apolaki_db -f config/init-db.sql",
    "db:seed": "npm run seed --prefix seeds",
    "docker:build": "docker-compose -f config/docker-compose.yml build",
    "docker:up": "docker-compose -f config/docker-compose.yml up -d",
    "docker:down": "docker-compose -f config/docker-compose.yml down",
    "docker:logs": "docker-compose -f config/docker-compose.yml logs -f",
    "netlify:build": "npm run build:netlify",
    "netlify:dev": "npm run dev",
    "deploy:netlify": "npm run pre-deploy && npm run build:netlify && netlify deploy --prod",
    "deploy:heroku": "npm run pre-deploy && npm run build:all && git push heroku main",
    "test:regression": "npm run test:regression --prefix tests",
    "test:regression:api": "npm run test:regression:api --prefix tests",
    "test:regression:ui": "npm run test:regression:ui --prefix tests",
    "pre-deploy": "bash scripts/pre-deploy-check.sh --quick",
    "pre-deploy:full": "bash scripts/pre-deploy-check.sh"
  },
  "dependencies": {
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apolaki-solar/platform.git"
  },
  "keywords": [
    "solar",
    "energy",
    "monitoring",
    "renewable",
    "management"
  ],
  "author": "Apolaki",
  "license": "MIT"
}
