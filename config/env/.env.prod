# ============================================================================
# Apolaki Solar Platform - Production Environment Configuration
# WARNING: NEVER commit real credentials to version control
# Use environment management tools: GitHub Secrets, Kubernetes Secrets, Vault, etc.
# ============================================================================

# Application Settings
APP_NAME=Apolaki
APP_ENV=production
APP_DEBUG=false
APP_PORT=3000
APP_URL=https://apolaki.com

# Database Configuration
DB_HOST=postgres.production.internal
DB_PORT=5432
DB_USER=apolaki_prod_user
DB_PASS=USE_VAULT_OR_SECRETS_MANAGER
DB_NAME=apolaki_db_prod
DB_SSL=true
DB_POOL_MIN=10
DB_POOL_MAX=50

# Redis Configuration
REDIS_HOST=redis-cluster.production.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=USE_VAULT_OR_SECRETS_MANAGER

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq-cluster.production.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=apolaki_prod
RABBITMQ_PASS=USE_VAULT_OR_SECRETS_MANAGER
RABBITMQ_VHOST=/apolaki

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch-cluster.production.internal
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=apolaki-prod

# JWT Authentication
JWT_SECRET=USE_VAULT_OR_SECRETS_MANAGER_STRONG_SECRET
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=USE_VAULT_OR_SECRETS_MANAGER_STRONG_SECRET
JWT_REFRESH_EXPIRATION=7d

# API Configuration
API_PORT=8080
API_HOST=0.0.0.0
API_BASE_URL=https://api.apolaki.com/api
API_TIMEOUT=30000

# Frontend Configuration
VITE_API_URL=https://api.apolaki.com/api
VITE_WS_URL=wss://api.apolaki.com/ws
VITE_APP_NAME=Apolaki
VITE_APP_ENV=production

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID=CHANGE_IN_PRODUCTION
OAUTH_GOOGLE_CLIENT_SECRET=USE_VAULT_OR_SECRETS_MANAGER
OAUTH_FACEBOOK_CLIENT_ID=CHANGE_IN_PRODUCTION
OAUTH_FACEBOOK_CLIENT_SECRET=USE_VAULT_OR_SECRETS_MANAGER
OAUTH_INSTAGRAM_CLIENT_ID=CHANGE_IN_PRODUCTION
OAUTH_INSTAGRAM_CLIENT_SECRET=USE_VAULT_OR_SECRETS_MANAGER
OAUTH_REDIRECT_URI=https://apolaki.com/auth/callback

# Viber & Telegram Configuration
VIBER_BOT_TOKEN=USE_VAULT_OR_SECRETS_MANAGER
VIBER_BOT_NAME=Apolaki
VIBER_WEBHOOK_URL=https://api.apolaki.com/webhooks/viber

TELEGRAM_BOT_TOKEN=USE_VAULT_OR_SECRETS_MANAGER
TELEGRAM_BOT_USERNAME=apolaki_bot
TELEGRAM_WEBHOOK_URL=https://api.apolaki.com/webhooks/telegram

# External Services
WEATHER_API_KEY=USE_VAULT_OR_SECRETS_MANAGER
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# AWS/S3 Configuration
AWS_ACCESS_KEY_ID=USE_VAULT_OR_SECRETS_MANAGER
AWS_SECRET_ACCESS_KEY=USE_VAULT_OR_SECRETS_MANAGER
AWS_REGION=us-east-1
S3_BUCKET=apolaki-prod
S3_ENDPOINT=s3.amazonaws.com

# CDN Configuration
CDN_ENABLED=true
CDN_URL=https://cdn.apolaki.com

# Logging Configuration
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/apolaki
LOG_RETENTION_DAYS=30

# Monitoring & Performance
SENTRY_DSN=USE_VAULT_OR_SECRETS_MANAGER
MONITORING_ENABLED=true
METRICS_ENABLED=true
APM_ENABLED=true

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=USE_VAULT_OR_SECRETS_MANAGER
SMTP_FROM=noreply@apolaki.com

# Security
CORS_ORIGINS=https://apolaki.com,https://www.apolaki.com
CORS_CREDENTIALS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
FEATURE_ANALYTICS=true
FEATURE_TRADING=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_VIBER=true
FEATURE_TELEGRAM=true
FEATURE_AI_TRADING=false

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Performance
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
COMPRESSION_ENABLED=true

