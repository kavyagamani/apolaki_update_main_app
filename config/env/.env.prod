DATABASE_URL = postgresql://neondb_owner:npg_e1z3gFjLxXIy@ep-withered-bar-ajdzzk54-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

DB_API_URL=https://ep-withered-bar-ajdzzk54.apirest.c-3.us-east-2.aws.neon.tech/neondb/rest/v1

Auth_url=https://ep-withered-bar-ajdzzk54.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth
JWKS_url=https://ep-withered-bar-ajdzzk54.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth/.well-known/jwks.json
