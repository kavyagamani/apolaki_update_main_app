# ============================================================================
# Apolaki Solar Platform - Staging Environment Configuration
# ============================================================================

# Application Settings
APP_NAME=Apolaki
APP_ENV=staging
APP_DEBUG=false
APP_PORT=3000
APP_URL=https://staging.apolaki.com

# Database Configuration
DB_HOST=postgres-staging.internal
DB_PORT=5432
DB_USER=apolaki_user
DB_PASS=CHANGE_THIS_PASSWORD
DB_NAME=apolaki_db_staging
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis Configuration
REDIS_HOST=redis-staging.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_THIS_PASSWORD

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq-staging.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=apolaki_staging
RABBITMQ_PASS=CHANGE_THIS_PASSWORD
RABBITMQ_VHOST=/apolaki-staging

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch-staging.internal
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=apolaki-staging

# JWT Authentication
JWT_SECRET=CHANGE_THIS_JWT_SECRET_STAGING
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=CHANGE_THIS_JWT_REFRESH_SECRET_STAGING
JWT_REFRESH_EXPIRATION=7d

# API Configuration
API_PORT=8080
API_HOST=0.0.0.0
API_BASE_URL=https://api-staging.apolaki.com/api
API_TIMEOUT=30000

# Frontend Configuration
VITE_API_URL=https://api-staging.apolaki.com/api
VITE_WS_URL=wss://api-staging.apolaki.com/ws
VITE_APP_NAME=Apolaki Staging
VITE_APP_ENV=staging

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID=your_staging_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=CHANGE_THIS
OAUTH_FACEBOOK_CLIENT_ID=your_staging_facebook_client_id
OAUTH_FACEBOOK_CLIENT_SECRET=CHANGE_THIS
OAUTH_INSTAGRAM_CLIENT_ID=your_staging_instagram_client_id
OAUTH_INSTAGRAM_CLIENT_SECRET=CHANGE_THIS
OAUTH_REDIRECT_URI=https://staging.apolaki.com/auth/callback

# Viber & Telegram Configuration
VIBER_BOT_TOKEN=CHANGE_THIS_STAGING_TOKEN
VIBER_BOT_NAME=Apolaki-Staging
VIBER_WEBHOOK_URL=https://api-staging.apolaki.com/webhooks/viber

TELEGRAM_BOT_TOKEN=CHANGE_THIS_STAGING_TOKEN
TELEGRAM_BOT_USERNAME=apolaki_staging_bot
TELEGRAM_WEBHOOK_URL=https://api-staging.apolaki.com/webhooks/telegram

# External Services
WEATHER_API_KEY=your_openweather_api_key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# AWS/S3 Configuration
AWS_ACCESS_KEY_ID=CHANGE_THIS
AWS_SECRET_ACCESS_KEY=CHANGE_THIS
AWS_REGION=us-east-1
S3_BUCKET=apolaki-staging
S3_ENDPOINT=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/apolaki

# Monitoring & Performance
SENTRY_DSN=https://CHANGE_THIS@sentry.io/PROJECT_ID
MONITORING_ENABLED=true
METRICS_ENABLED=true

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_THIS_SENDGRID_KEY
SMTP_FROM=noreply@staging.apolaki.com

# Feature Flags
FEATURE_ANALYTICS=true
FEATURE_TRADING=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_VIBER=true
FEATURE_TELEGRAM=true
