# ============================================================================
# Apolaki Solar Platform - Development Environment Configuration
# ============================================================================

# Application Settings
APP_NAME=Apolaki
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=apolaki_user
DB_PASSWORD=apolaki_pass
DB_NAME=apolaki_db
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration (Caching & Sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ Configuration (Message Queue)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=apolaki
RABBITMQ_PASS=apolaki_pass
RABBITMQ_VHOST=/apolaki

# Elasticsearch Configuration (Search & Analytics)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=apolaki-dev

# JWT Authentication
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# API Configuration
API_PORT=8080
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:8080/api
API_TIMEOUT=30000

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_NAME=Apolaki
VITE_APP_ENV=development

# OAuth Configuration (Social Login)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_FACEBOOK_CLIENT_ID=your_facebook_client_id
OAUTH_FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
OAUTH_INSTAGRAM_CLIENT_ID=your_instagram_client_id
OAUTH_INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Viber & Telegram Bot Configuration
VIBER_BOT_TOKEN=your_viber_bot_token
VIBER_BOT_NAME=Apolaki
VIBER_WEBHOOK_URL=http://localhost:8080/webhooks/viber

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=apolaki_bot
TELEGRAM_WEBHOOK_URL=http://localhost:8080/webhooks/telegram

# External Services
WEATHER_API_KEY=your_openweather_api_key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# AWS/S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=apolaki-dev
S3_ENDPOINT=

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# Monitoring & Performance
SENTRY_DSN=
MONITORING_ENABLED=true
METRICS_ENABLED=true

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@apolaki.local

