# Netlify DB Configuration
# Copy to .env and update with your database credentials

# Database Connection String for Netlify DB
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://apolaki_user:apolaki_pass@localhost:5432/apolaki_db

# Alternative PostgreSQL URL format
POSTGRES_URL=postgresql://apolaki_user:apolaki_pass@localhost:5432/apolaki_db

# Database Name
DB_NAME=apolaki_db

# Database Host
DB_HOST=localhost

# Database Port
DB_PORT=5432

# Database User
DB_USER=apolaki_user

# Database Password
DB_PASSWORD=your_secure_password

# Server Configuration
PORT=8080
ENV=development
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Service Configuration
SERVICE_NAME=solar-service
SERVICE_VERSION=1.0.0
